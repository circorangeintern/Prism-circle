NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=powerwatch

JWT_ACCESS_SECRET=change-this-to-a-random-secret
JWT_REFRESH_SECRET=change-this-to-a-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

BCRYPT_SALT_ROUNDS=12

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

CORS_ORIGIN=http://localhost:5173

ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@powerwatch.com
ADMIN_PASSWORD=Admin@123

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=no-reply@powerwatch.com
SMTP_FROM_NAME=PowerWatch
